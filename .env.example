# =============================================================================
# Viral Shorts Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated list of admin Telegram user IDs
# To find your ID, message @userinfobot
TELEGRAM_ADMIN_IDS=

# Optional: UserBot session string for advanced features (e.g. forwarding)
TELEGRAM_SESSION_STRING=

# Polling interval in seconds (0 = instant)
TELEGRAM_POLLING_INTERVAL=0

# -----------------------------------------------------------------------------
# Groq API (free tier available at https://console.groq.com)
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# Groq model for speech-to-text (Whisper)
# Options: whisper-large-v3, whisper-large-v3-turbo
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Groq LLM model for viral moment detection and title generation
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Groq API base URL (usually no need to change)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# -----------------------------------------------------------------------------
# FFmpeg Configuration
# -----------------------------------------------------------------------------
# Number of threads for FFmpeg encoding (set to number of CPU cores)
FFMPEG_THREADS=4

# Hardware acceleration: auto, cuda, vaapi, qsv, or none
FFMPEG_HWACCEL=auto

# Encoding preset: ultrafast, superfast, veryfast, faster, fast, medium, slow
FFMPEG_PRESET=medium

# Maximum video duration in seconds (0 = unlimited)
FFMPEG_MAX_DURATION_SECONDS=3600

# -----------------------------------------------------------------------------
# Output Video Settings
# -----------------------------------------------------------------------------
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
OUTPUT_FPS=30
OUTPUT_VIDEO_CODEC=libx264
OUTPUT_AUDIO_CODEC=aac
OUTPUT_VIDEO_BITRATE=8M
OUTPUT_AUDIO_BITRATE=192k
OUTPUT_PIXEL_FORMAT=yuv420p

# -----------------------------------------------------------------------------
# Short Clip Settings
# -----------------------------------------------------------------------------
MAX_SHORTS_DURATION_SECONDS=60
MIN_SHORTS_DURATION_SECONDS=15

# -----------------------------------------------------------------------------
# Queue System
# -----------------------------------------------------------------------------
QUEUE_MAX_CONCURRENT_JOBS=2
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_SECONDS=10
QUEUE_JOB_TIMEOUT_SECONDS=1800

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Maximum upload file size in bytes (default: 2 GB)
MAX_UPLOAD_SIZE_BYTES=2147483648

# Maximum download (YouTube) size in bytes (default: 4 GB)
MAX_DOWNLOAD_SIZE_BYTES=4294967296

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# Caption Styling
# -----------------------------------------------------------------------------
CAPTION_STYLE=hormozi
CAPTION_COLOR=#FFFFFF
CAPTION_HIGHLIGHT_COLOR=#FFD700
CAPTION_FONT_SIZE=48
CAPTION_STROKE_COLOR=#000000
CAPTION_STROKE_WIDTH=2
